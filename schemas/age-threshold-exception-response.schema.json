{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://minimal-age-disclosure.example/schemas/age-threshold-exception-response.schema.json",
  "title": "Age Threshold Exception Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "object_type",
    "object_version",
    "normal_flow_conformance",
    "profile_ref",
    "base_request_ref",
    "verifier_id",
    "audience_binding",
    "nonce_binding",
    "lawful_basis_code",
    "lawful_basis_ref",
    "jurisdiction_ref",
    "purpose",
    "retention_period",
    "red_path_confirmation",
    "disclosed_fields",
    "withheld_fields",
    "holder_decision",
    "retention_notice_acknowledged",
    "disclosure_scope",
    "review_or_appeal_ref",
    "response_expiry"
  ],
  "properties": {
    "object_type": { "const": "age_threshold_exception_response" },
    "object_version": { "const": "1.0" },
    "normal_flow_conformance": { "const": false },
    "profile_ref": { "enum": ["Profile R", "Profile P"] },
    "base_request_ref": { "type": "string", "minLength": 1 },
    "verifier_id": { "type": "string", "minLength": 1 },
    "audience_binding": { "const": "present" },
    "nonce_binding": { "const": "present" },
    "lawful_basis_code": { "type": "string", "minLength": 1 },
    "lawful_basis_ref": { "type": "string", "minLength": 1 },
    "jurisdiction_ref": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "retention_period": { "type": "object" },
    "red_path_confirmation": { "type": "object" },
    "disclosed_fields": { "type": "object" },
    "withheld_fields": { "type": "array", "items": { "type": "string" } },
    "holder_decision": { "enum": ["accepted_all", "accepted_partial", "refused", "cancelled"] },
    "retention_notice_acknowledged": { "type": "boolean" },
    "disclosure_scope": { "type": "array", "items": { "type": "string" } },
    "review_or_appeal_ref": { "type": "string", "minLength": 1 },
    "response_expiry": { "type": "string", "minLength": 1 },
    "audit_event_ref": { "type": "string", "minLength": 1 }
  }
}
